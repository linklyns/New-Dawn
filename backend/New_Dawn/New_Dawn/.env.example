SUPABASE_CONNECTION_STRING=Host=YOUR_SUPABASE_HOST;Port=5432;Database=postgres;Username=postgres;Password=YOUR_PASSWORD;SSL Mode=Require;Trust Server Certificate=true
JWT_SECRET=YourSuperSecretKeyThatIsAtLeast32CharactersLong
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GEMINI_API_KEY=your-gemini-api-key
# Optional single-model override
GEMINI_MODEL=gemini-2.5-flash
# Preferred fallback chain for cheaper, higher-throughput models
GEMINI_MODELS=gemini-2.5-flash-lite,gemini-2.5-flash,gemini-2.0-flash-lite,gemini-2.0-flash
